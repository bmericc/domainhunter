{
    "name": "bahrimeric/seo-ai-checker",
    "description": "Web scraping ile Google SERP siralama, AI Overview gorunurlugu ve on-page SEO kontrolu yapan bagimsiz CLI araci",
    "type": "project",
    "license": "GPL-3.0-or-later",
    "require": {
        "php": "^8.1",
        "ext-mbstring": "*",
        "guzzlehttp/guzzle": "^7.8",
        "symfony/console": "^7.0",
        "symfony/dom-crawler": "^7.0",
        "symfony/css-selector": "^7.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "SeoAiChecker\\": "src/"
        }
    },
    "bin": [
        "bin/seo-check"
    ],
    "config": {
        "sort-packages": true
    }
}
