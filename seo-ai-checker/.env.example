# Google arama arayuzu dili/bolgesi (SERP sonuclarini etkiler)
GOOGLE_HL=tr
GOOGLE_GL=tr

# Istekler arasi bekleme suresi (ms) - Google tarafindan engellenmemek icin
REQUEST_DELAY_MS=4000

# Istege bagli HTTP proxy (ornek: http://user:pass@proxyhost:8080)
HTTP_PROXY=

# Istege bagli ozel User-Agent (bos birakilirsa varsayilan masaustu Chrome UA kullanilir)
USER_AGENT=
