<!DOCTYPE html>
<html lang="{{ t.locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Domain Hunter</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg:          #f1f5f9;
            --surface:     #ffffff;
            --border:      #e2e8f0;
            --text:        #0f172a;
            --text-muted:  #64748b;
            --accent:      #f59e0b;
            --accent-dark: #d97706;
            --header-bg:   #0f172a;
            --radius:      10px;
            --shadow:      0 1px 3px rgba(0,0,0,.06), 0 2px 8px rgba(0,0,0,.04);
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            font-size: 14px;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
        }

        /* ── Header ─────────────────────────────────────── */
        header {
            background: var(--header-bg);
            padding: 0 2rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            height: 62px;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: 0 1px 0 rgba(255,255,255,.06), 0 4px 16px rgba(0,0,0,.2);
        }

        .header-left { display: flex; align-items: center; gap: 2.5rem; }

        .logo-link {
            display: flex;
            align-items: center;
            text-decoration: none;
        }
        .logo-img {
            height: 38px;
            filter: brightness(0) invert(1);
            opacity: .92;
            transition: opacity .15s;
        }
        .logo-link:hover .logo-img { opacity: 1; }

        nav { display: flex; gap: .2rem; }
        nav a {
            color: #94a3b8;
            text-decoration: none;
            padding: .4rem .9rem;
            border-radius: 6px;
            font-size: .82rem;
            font-weight: 500;
            transition: background .15s, color .15s;
        }
        nav a:hover { background: rgba(255,255,255,.07); color: #f1f5f9; }

        .nav-add {
            background: var(--accent) !important;
            color: #fff !important;
            font-weight: 600 !important;
            padding: .4rem 1rem !important;
        }
        .nav-add:hover { background: var(--accent-dark) !important; }

        /* ── Main ────────────────────────────────────────── */
        main { max-width: 1200px; margin: 2rem auto; padding: 0 1.5rem; }

        /* ── Card ────────────────────────────────────────── */
        .card {
            background: var(--surface);
            border-radius: var(--radius);
            border: 1px solid var(--border);
            box-shadow: var(--shadow);
        }

        .card-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 1.25rem 1.5rem;
            border-bottom: 1px solid var(--border);
        }

        .card-body { padding: 1.5rem; }

        h2 { font-size: .95rem; font-weight: 700; color: var(--text); }

        /* ── Table ───────────────────────────────────────── */
        table { width: 100%; border-collapse: collapse; }

        thead th {
            text-align: left;
            font-weight: 600;
            font-size: .68rem;
            text-transform: uppercase;
            letter-spacing: .07em;
            color: var(--text-muted);
            padding: .65rem 1.25rem;
            background: #f8fafc;
            border-bottom: 1px solid var(--border);
            white-space: nowrap;
        }
        th a { color: inherit; text-decoration: none; }
        th a:hover { color: var(--accent); }

        tbody td {
            padding: .7rem 1.25rem;
            border-bottom: 1px solid #f1f5f9;
            vertical-align: middle;
            font-size: .84rem;
        }
        tbody tr:last-child td { border-bottom: none; }
        tbody tr:hover td { background: #fafbfd; }

        /* ── Badges ──────────────────────────────────────── */
        .badge {
            display: inline-flex;
            align-items: center;
            padding: .18rem .55rem;
            border-radius: 999px;
            font-size: .68rem;
            font-weight: 700;
            letter-spacing: .03em;
            text-transform: uppercase;
        }
        .badge-ok   { background: #dcfce7; color: #166534; }
        .badge-warn { background: #fef3c7; color: #92400e; }
        .badge-err  { background: #fee2e2; color: #991b1b; }
        .badge-blue { background: #dbeafe; color: #1e40af; }

        /* ── Buttons ─────────────────────────────────────── */
        .btn {
            display: inline-flex;
            align-items: center;
            gap: .3rem;
            padding: .45rem 1.1rem;
            border-radius: 7px;
            font-size: .82rem;
            font-weight: 600;
            cursor: pointer;
            border: none;
            transition: all .15s;
            text-decoration: none;
            line-height: 1;
        }
        .btn-primary { background: var(--accent); color: #fff; }
        .btn-primary:hover { background: var(--accent-dark); }
        .btn-secondary {
            background: transparent;
            color: var(--text-muted);
            border: 1px solid var(--border);
        }
        .btn-secondary:hover { background: var(--bg); color: var(--text); }
        .btn-danger {
            background: transparent;
            color: #dc2626;
            border: 1px solid #fecaca;
            padding: .28rem .7rem;
            font-size: .75rem;
            border-radius: 5px;
        }
        .btn-danger:hover { background: #fef2f2; }
        .btn-sm { padding: .3rem .75rem; font-size: .76rem; }

        /* ── Alerts ──────────────────────────────────────── */
        .alert {
            padding: .9rem 1.1rem;
            border-radius: 7px;
            margin-bottom: 1.25rem;
            font-size: .86rem;
            border: 1px solid transparent;
        }
        .alert-success { background: #f0fdf4; color: #166534; border-color: #bbf7d0; }
        .alert-error   { background: #fef2f2; color: #991b1b; border-color: #fecaca; }

        /* ── Form ────────────────────────────────────────── */
        .form-group { margin-bottom: 1.25rem; }
        label { display: block; font-weight: 600; margin-bottom: .4rem; font-size: .82rem; }
        input[type=text] {
            width: 100%;
            max-width: 400px;
            padding: .6rem .9rem;
            border: 1.5px solid var(--border);
            border-radius: 7px;
            font-size: .9rem;
            outline: none;
            transition: border-color .15s, box-shadow .15s;
            background: var(--bg);
            color: var(--text);
        }
        input[type=text]:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(245,158,11,.12);
            background: #fff;
        }
        input[type=text]::placeholder { color: #94a3b8; }

        /* ── Pagination ──────────────────────────────────── */
        .pagination { display: flex; gap: .35rem; margin-top: 1.25rem; justify-content: flex-end; }
        .pagination a, .pagination span {
            padding: .3rem .65rem;
            border-radius: 5px;
            font-size: .78rem;
            font-weight: 500;
            text-decoration: none;
            color: var(--text);
            border: 1px solid var(--border);
            background: var(--surface);
        }
        .pagination a:hover { border-color: var(--accent); color: var(--accent); }
        .pagination .current { background: var(--accent); color: #fff; border-color: var(--accent); font-weight: 700; }

        /* ── Misc ────────────────────────────────────────── */
        .domain-link { color: #2563eb; text-decoration: none; font-weight: 600; }
        .domain-link:hover { text-decoration: underline; color: #1d4ed8; }
        .text-muted   { color: var(--text-muted); }
        .count-badge  { color: var(--accent); font-weight: 700; margin-left: .3rem; }
        .expiry-urgent  { color: #dc2626; font-weight: 700; }
        .expiry-warning { color: #d97706; font-weight: 600; }
    </style>
</head>
<body>
    <header>
        <div class="header-left">
            <a href="/" class="logo-link">
                <img src="/logo.svg" alt="Domain Hunter" class="logo-img">
            </a>
            <nav>
                <a href="/">{{ t.nav_domains }}</a>
            </nav>
        </div>
        <nav>
            <a href="/domains/add" class="nav-add">{{ t.nav_add }}</a>
        </nav>
    </header>
    <main>
        {% block content %}{% endblock %}
    </main>
</body>
</html>
