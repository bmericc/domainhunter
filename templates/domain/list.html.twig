{% extends 'layout.html.twig' %}

{% block content %}
<div class="card">
    <h2>
        {{ t.heading_list }}
        <span class="count-badge">({{ total }})</span>
        <a href="/domains/add" class="btn btn-primary btn-sm" style="float:right">{{ t.nav_add }}</a>
    </h2>

    {% if domains is empty %}
        <p class="text-muted" style="padding:1rem 0">{{ t.no_domains }} <a href="/domains/add">{{ t.add_one }}</a></p>
    {% else %}
        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>{{ t.col_domain }}</th>
                    <th>{{ t.col_status }}</th>
                    <th>{{ t.col_registrar }}</th>
                    <th>{{ t.col_created }}</th>
                    <th>
                        <a href="?order=updated{% if page > 1 %}&page={{ page }}{% endif %}">
                            {{ t.col_updated }} {% if order == 'updated' %}&#9660;{% endif %}
                        </a>
                    </th>
                    <th>
                        <a href="?order=expiry{% if page > 1 %}&page={{ page }}{% endif %}">
                            {{ t.col_expires }} {% if order == 'expiry' %}&#9660;{% endif %}
                        </a>
                    </th>
                    <th>
                        <a href="?order=checked{% if page > 1 %}&page={{ page }}{% endif %}">
                            {{ t.col_last_check }} {% if order == 'checked' %}&#9660;{% endif %}
                        </a>
                    </th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for domain in domains %}
                {% set row_num = (page - 1) * per_page + loop.index %}
                <tr>
                    <td class="text-muted">{{ row_num }}</td>
                    <td>
                        <a class="domain-link"
                           href="https://whois.domaintools.com/{{ domain.domain|lower }}"
                           target="_blank" rel="noopener">
                            {{ domain.domain }}
                        </a>
                    </td>
                    <td>
                        {% if domain.status1 %}
                            {% if 'ok' in domain.status1|lower or 'active' in domain.status1|lower %}
                                <span class="badge badge-ok">{{ domain.status1 }}</span>
                            {% elseif 'hold' in domain.status1|lower or 'delete' in domain.status1|lower %}
                                <span class="badge badge-warn">{{ domain.status1 }}</span>
                            {% else %}
                                <span class="badge">{{ domain.status1 }}</span>
                            {% endif %}
                        {% else %}
                            <span class="text-muted">—</span>
                        {% endif %}
                    </td>
                    <td>{{ domain.register ?: '—' }}</td>
                    <td class="text-muted">{{ domain.create_date ?: '—' }}</td>
                    <td class="text-muted">{{ domain.update_date ?: '—' }}</td>
                    <td>
                        {% if domain.expirate_date and domain.expirate_date != '0000-00-00' %}
                            {% set days_left = ((domain.expirate_date|date('U') - 'now'|date('U')) / 86400)|round %}
                            {% if days_left < 30 %}
                                <span style="color:#c62828;font-weight:600">{{ domain.expirate_date }}</span>
                            {% elseif days_left < 90 %}
                                <span style="color:#f57f17;font-weight:600">{{ domain.expirate_date }}</span>
                            {% else %}
                                {{ domain.expirate_date }}
                            {% endif %}
                        {% else %}
                            <span class="text-muted">—</span>
                        {% endif %}
                    </td>
                    <td class="text-muted">{{ domain.hunter_update ? domain.hunter_update|slice(0,16) : '—' }}</td>
                    <td>
                        <form method="post" action="/domains/{{ domain.id }}/delete"
                              onsubmit="return confirm('{{ t.confirm_delete|replace({'{domain}': domain.domain})|e('js') }}')">
                            <button type="submit" class="btn btn-danger btn-sm">{{ t.btn_delete }}</button>
                        </form>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>

        {% if total_pages > 1 %}
        <div class="pagination">
            {% if page > 1 %}
                <a href="?order={{ order }}&page={{ page - 1 }}">{{ t.pag_prev }}</a>
            {% endif %}
            {% for p in 1..total_pages %}
                {% if p == page %}
                    <span class="current">{{ p }}</span>
                {% else %}
                    <a href="?order={{ order }}&page={{ p }}">{{ p }}</a>
                {% endif %}
            {% endfor %}
            {% if page < total_pages %}
                <a href="?order={{ order }}&page={{ page + 1 }}">{{ t.pag_next }}</a>
            {% endif %}
        </div>
        {% endif %}
    {% endif %}
</div>
{% endblock %}
