{% extends 'layout.html.twig' %}

{% block content %}
<div class="card">
    <div class="card-head">
        <h2>{{ t.heading_list }}<span class="count-badge">{{ total }}</span></h2>
    </div>

    {% if domains is empty %}
        <div class="card-body">
            <p class="text-muted">{{ t.no_domains }} <a href="/domains/add" style="color:var(--accent)">{{ t.add_one }}</a></p>
        </div>
    {% else %}
        <table>
            <thead>
                <tr>
                    <th style="width:40px">#</th>
                    <th>{{ t.col_domain }}</th>
                    <th>{{ t.col_status }}</th>
                    <th>{{ t.col_registrar }}</th>
                    <th>{{ t.col_created }}</th>
                    <th>
                        <a href="?order=updated{% if page > 1 %}&page={{ page }}{% endif %}">
                            {{ t.col_updated }}{% if order == 'updated' %} ▾{% endif %}
                        </a>
                    </th>
                    <th>
                        <a href="?order=expiry{% if page > 1 %}&page={{ page }}{% endif %}">
                            {{ t.col_expires }}{% if order == 'expiry' %} ▾{% endif %}
                        </a>
                    </th>
                    <th>
                        <a href="?order=checked{% if page > 1 %}&page={{ page }}{% endif %}">
                            {{ t.col_last_check }}{% if order == 'checked' %} ▾{% endif %}
                        </a>
                    </th>
                    <th style="width:70px"></th>
                </tr>
            </thead>
            <tbody>
                {% for domain in domains %}
                {% set row_num = (page - 1) * per_page + loop.index %}
                <tr>
                    <td class="text-muted">{{ row_num }}</td>
                    <td>
                        <a class="domain-link"
                           href="https://whois.domaintools.com/{{ domain.domain|lower }}"
                           target="_blank" rel="noopener">{{ domain.domain }}</a>
                    </td>
                    <td>
                        {% if domain.status1 %}
                            {% set s = domain.status1|lower %}
                            {% if 'ok' in s or 'active' in s %}
                                <span class="badge badge-ok">{{ domain.status1 }}</span>
                            {% elseif 'hold' in s or 'delete' in s or 'suspend' in s %}
                                <span class="badge badge-warn">{{ domain.status1 }}</span>
                            {% else %}
                                <span class="badge badge-blue">{{ domain.status1 }}</span>
                            {% endif %}
                        {% else %}
                            <span class="text-muted">—</span>
                        {% endif %}
                    </td>
                    <td>{{ domain.register ?: '<span class="text-muted">—</span>'|raw }}</td>
                    <td class="text-muted">{{ domain.create_date ?: '—' }}</td>
                    <td class="text-muted">{{ domain.update_date ?: '—' }}</td>
                    <td>
                        {% if domain.expirate_date and domain.expirate_date != '0000-00-00' %}
                            {% set days_left = ((domain.expirate_date|date('U') - 'now'|date('U')) / 86400)|round %}
                            {% if days_left < 30 %}
                                <span class="expiry-urgent">{{ domain.expirate_date }}</span>
                            {% elseif days_left < 90 %}
                                <span class="expiry-warning">{{ domain.expirate_date }}</span>
                            {% else %}
                                {{ domain.expirate_date }}
                            {% endif %}
                        {% else %}
                            <span class="text-muted">—</span>
                        {% endif %}
                    </td>
                    <td class="text-muted">{{ domain.hunter_update ? domain.hunter_update|slice(0,16) : '—' }}</td>
                    <td>
                        <form method="post" action="/domains/{{ domain.id }}/delete"
                              onsubmit="return confirm('{{ t.confirm_delete|replace({'{domain}': domain.domain})|e('js') }}')">
                            <button type="submit" class="btn btn-danger">{{ t.btn_delete }}</button>
                        </form>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>

        {% if total_pages > 1 %}
        <div class="pagination" style="padding:1rem 1.25rem 1.25rem">
            {% if page > 1 %}
                <a href="?order={{ order }}&page={{ page - 1 }}">{{ t.pag_prev }}</a>
            {% endif %}
            {% for p in 1..total_pages %}
                {% if p == page %}
                    <span class="current">{{ p }}</span>
                {% else %}
                    <a href="?order={{ order }}&page={{ p }}">{{ p }}</a>
                {% endif %}
            {% endfor %}
            {% if page < total_pages %}
                <a href="?order={{ order }}&page={{ page + 1 }}">{{ t.pag_next }}</a>
            {% endif %}
        </div>
        {% endif %}
    {% endif %}
</div>
{% endblock %}
