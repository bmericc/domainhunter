APP_ENV=production
APP_DEBUG=false

# Web arayüzü dili: en | tr | de | es | pt | ru  (varsayılan: en)
APP_LANG=en

# Database driver: "mysql" or "sqlite"
DB_DRIVER=mysql

# MySQL settings (used when DB_DRIVER=mysql)
DB_HOST=localhost
DB_NAME=domainhunter
DB_USER=root
DB_PASS=

# SQLite settings (used when DB_DRIVER=sqlite)
# DB_PATH=/absolute/path/to/domainhunter.sqlite

ALERT_EMAIL=admin@example.com

# SMTP / email gönderimi (ayarlanmazsa PHP mail() kullanılır)
# MAILER_DSN=smtp://user:pass@smtp.example.com:587
# MAILER_DSN=smtp://user:pass@smtp.gmail.com:465?encryption=tls
# MAILER_DSN=native://default
# MAILER_FROM=domainhunter@example.com
